# Aperture local runtime
APERTURE_AGENT_MODEL=claude-haiku-4-5
APERTURE_AGENT_MAX_STEPS=6
APERTURE_AGENT_MAX_TOKENS=1024
APERTURE_AGENT_PARALLEL=5

# Required only for the live Claude + Composio agent path.
ANTHROPIC_API_KEY=
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=

# Connected account IDs used to scope private execution-cache keys.
# Preferred names.
COMPOSIO_GITHUB_CONNECTED_ACCOUNT_ID=
COMPOSIO_GMAIL_CONNECTED_ACCOUNT_ID=
COMPOSIO_SLACK_CONNECTED_ACCOUNT_ID=
COMPOSIO_NOTION_CONNECTED_ACCOUNT_ID=
COMPOSIO_LINEAR_CONNECTED_ACCOUNT_ID=
COMPOSIO_GOOGLESHEETS_CONNECTED_ACCOUNT_ID=
COMPOSIO_SUPABASE_CONNECTED_ACCOUNT_ID=

# Backward-compatible aliases also accepted by demos/API wiring.
COMPOSIO_GITHUB_ACCOUNT_ID=
COMPOSIO_GMAIL_ACCOUNT_ID=
COMPOSIO_YOUTUBE_ACCOUNT_ID=

# Optional generic fallback for demos that use fixture data.
COMPOSIO_CONNECTED_ACCOUNT_ID=

# Optional Redis/Upstash cache backend. In-memory cache is used when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
