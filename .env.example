# Composio
COMPOSIO_API_KEY=your_composio_api_key_here

# Upstash Redis (cache backend; in-memory fallback if unset)
UPSTASH_REDIS_REST_URL=https://just-dinosaur-119559.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Aperture
APERTURE_ENV=local

# Optional model-tier field classifier
# ------------------------------------
# Aperture's smart field policy can call a small model once per (tool, ask)
# to decide which "denial-list" fields the agent actually needs for *this*
# call. Default provider is HuggingFace using a small Gemma base model;
# Anthropic Haiku is also supported. Set APERTURE_CLASSIFIER_PROVIDER=none
# to disable the model tier entirely (ask-aware policy still runs).

# huggingface | anthropic | none
APERTURE_CLASSIFIER_PROVIDER=huggingface

# Optional model override. HF defaults to meta-llama/Llama-3.1-8B-Instruct,
# which the free hf-inference router serves. Other models confirmed available
# (probe via /api/field-policy/health):
#   meta-llama/Llama-3.2-1B-Instruct       (tiny but echoes/over-promotes)
#   meta-llama/Llama-3.1-8B-Instruct       (default — solid selectivity)
#   Qwen/Qwen2.5-7B-Instruct               (sharp structured output)
#   meta-llama/Llama-3.3-70B-Instruct      (heaviest, most accurate)
#   Qwen/Qwen2.5-72B-Instruct
# Gemma / SmolLM / Mistral 7B / Phi all 400 on the current free tier.
# APERTURE_CLASSIFIER_MODEL=meta-llama/Llama-3.1-8B-Instruct

# HuggingFace Inference API token (for Gemma classifier)
HF_API_TOKEN=hf_your_token_here

# Anthropic API key (only needed if APERTURE_CLASSIFIER_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
